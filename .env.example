# ─────────────────────────────────────────────────────────────────────────────
# Environment Configuration — ClipArt AI
#
# SECURITY RULES:
#   - Copy this file to .env for local development
#   - NEVER commit .env to version control
#   - NEVER add AI provider keys (OpenAI, Replicate, etc.) here
#   - All AI secrets must live on the backend server only
# ─────────────────────────────────────────────────────────────────────────────

# Backend proxy URL (points to your secure server — never a direct AI API)
BACKEND_URL=http://localhost:3000

# App environment
APP_ENV=development

# Request timeout in milliseconds
API_TIMEOUT=30000

# Max image size in bytes (default: 10MB)
MAX_IMAGE_SIZE=10485760

# Allowed upload formats (comma-separated)
SUPPORTED_FORMATS=jpg,jpeg,png

# Enable verbose logging in development
ENABLE_VERBOSE_LOGGING=true
